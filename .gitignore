# ===========================
# PGM联赛 .gitignore
# ===========================

# WorkBuddy 工作记忆文件（含敏感信息，不上传）
.workbuddy_memory_*.md
.workbuddy/

# 生成的图片（体积大，通过 CDN 或 LFS 管理）
generated-images/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器/IDE
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log

# Node.js（如果将来引入构建工具）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（切勿提交密码/密钥）
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.bak
